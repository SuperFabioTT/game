<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>极限分差数学挑战 | 简单2分·地狱50分</title>
    <style>
        * {
            box-sizing: border-box;
            user-select: none;
        }

        body {
            background: linear-gradient(135deg, #0b2b2b 0%, #1a3a3a 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', 'Poppins', 'Roboto', system-ui, sans-serif;
            margin: 0;
            padding: 20px;
        }

        .game-panel {
            max-width: 1000px;
            width: 100%;
            background: #fffef7;
            border-radius: 70px;
            box-shadow: 0 30px 50px rgba(0, 0, 0, 0.4);
            overflow: hidden;
        }

        .game-header {
            background: #f39c12;
            padding: 18px 25px;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            border-bottom: 5px solid #d35400;
        }

        .score-area {
            background: #1e3c2c;
            padding: 6px 20px;
            border-radius: 50px;
            color: #f9e0a0;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 1.3rem;
        }

        .score-area span:last-child {
            font-size: 1.9rem;
            font-weight: 800;
            color: #ffd966;
            min-width: 80px;
        }

        .mode-selector, .difficulty-selector {
            background: white;
            border-radius: 40px;
            padding: 5px 15px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: bold;
        }

        select {
            font-size: 1rem;
            padding: 6px 12px;
            border-radius: 30px;
            border: 1px solid #f39c12;
            background: #fff3e0;
            font-weight: bold;
            cursor: pointer;
        }

        .question-card {
            padding: 25px 30px 20px;
            background: #ffffff;
        }

        .question-text {
            background: #fef1df;
            padding: 30px 20px;
            border-radius: 50px;
            font-size: 1.45rem;
            line-height: 1.45;
            font-weight: 600;
            color: #2c3e2f;
            text-align: center;
            margin-bottom: 20px;
            box-shadow: inset 0 1px 5px rgba(0,0,0,0.05), 0 5px 0 #e2c7a3;
            word-break: break-word;
        }

        .answer-area {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            justify-content: center;
            margin: 20px 0;
        }

        .answer-input {
            flex: 3;
            min-width: 200px;
            padding: 14px 20px;
            font-size: 1.2rem;
            border: 3px solid #f5bc70;
            border-radius: 60px;
            font-family: monospace;
            font-weight: bold;
            text-align: center;
            background: #fffcf5;
            outline: none;
        }

        .submit-btn {
            background: #2ecc71;
            border: none;
            color: white;
            font-size: 1.2rem;
            font-weight: bold;
            padding: 12px 28px;
            border-radius: 50px;
            cursor: pointer;
            transition: 0.1s linear;
            box-shadow: 0 5px 0 #1f8f4b;
        }

        .submit-btn:active { transform: translateY(2px); box-shadow: 0 2px 0 #1f8f4b; }
        .next-btn { background: #e67e22; box-shadow: 0 5px 0 #b45f1b; }

        .feedback {
            background: #e7e3d8;
            border-radius: 40px;
            padding: 12px 20px;
            text-align: center;
            font-weight: bold;
            margin: 15px 0 10px;
            font-size: 1rem;
        }
        .feedback.correct { background: #c8e6d9; color: #1f5e2d; }
        .feedback.wrong { background: #ffdbd4; color: #bc2f1a; }

        .action-buttons {
            display: flex;
            justify-content: space-between;
            gap: 15px;
            margin-top: 15px;
        }
        .btn {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 40px;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.1s;
        }
        .btn-primary { background: #f1c40f; color: #2c3e2f; box-shadow: 0 4px 0 #b67e1a; }
        .btn-reset { background: #95a5a6; color: white; box-shadow: 0 4px 0 #6c7a7a; }
        .btn:active { transform: translateY(2px); box-shadow: 0 1px 0 #b67e1a; }
        .info-tip {
            font-size: 0.8rem;
            text-align: center;
            color: #a08154;
            padding: 12px;
            background: #faf0e1;
            border-radius: 30px;
            margin-top: 10px;
        }
        @media (max-width: 700px) {
            .game-header { flex-direction: column; align-items: stretch; }
            .question-text { font-size: 1.1rem; }
        }
    </style>
</head>
<body>
<div class="game-panel" id="gameApp">
    <div class="game-header">
        <div class="score-area"><span>🏆 积分</span><span id="scoreValue">0</span></div>
        <div class="mode-selector"><span>📚 模式：</span>
            <select id="modeSelect"><option value="calc">🧮 计算题</option><option value="word">📖 应用题</option></select>
        </div>
        <div class="difficulty-selector"><span>⚡ 难度：</span>
            <select id="difficultySelect">
                <option value="easy">🍃 简单 (2分/题)</option><option value="medium">🔥 中等 (5分/题)</option><option value="hard">💀 困难 (12分/题)</option><option value="hell">👹 地狱 (50分/题)</option>
            </select>
        </div>
    </div>
    <div class="question-card">
        <div class="question-text" id="questionText">选择难度 & 模式，开始冒险！</div>
        <div class="answer-area">
            <input type="text" id="answerInput" class="answer-input" placeholder="答案 (小数 或 分数 如 3/4)" autocomplete="off">
            <button id="submitBtn" class="submit-btn">✓ 提交</button>
        </div>
        <div class="feedback" id="feedbackMsg">🔥 地狱难度每题50分！超复杂异形/多步方程 🔥</div>
        <div class="action-buttons">
            <button id="nextBtn" class="btn btn-primary">🎲 下一题</button>
            <button id="resetBtn" class="btn btn-reset">🔄 重置分数</button>
        </div>
        <div class="info-tip">💡 得分系数：简单0.2倍(2分) | 中等0.5倍(5分) | 困难1.2倍(12分) | 地狱5.0倍(50分)。答案精确到0.001以内。</div>
    </div>
</div>

<script>
    // ======================== 难度配置：分差巨大 ========================
    const difficultyMap = {
        easy: { factor: 0.2, label: '🍃 简单', baseScore: 2 },    // 10*0.2 = 2分
        medium: { factor: 0.5, label: '🔥 中等', baseScore: 5 },   // 5分
        hard: { factor: 1.2, label: '💀 困难', baseScore: 12 },     // 12分
        hell: { factor: 5.0, label: '👹 地狱', baseScore: 50 }      // 50分
    };

    let currentMode = 'calc';
    let currentDifficulty = 'easy';
    let currentScore = 0;
    let currentQuestionObj = null;
    let canSubmit = true;

    // DOM
    const modeSelect = document.getElementById('modeSelect');
    const difficultySelect = document.getElementById('difficultySelect');
    const questionTextDiv = document.getElementById('questionText');
    const answerInput = document.getElementById('answerInput');
    const submitBtn = document.getElementById('submitBtn');
    const nextBtn = document.getElementById('nextBtn');
    const resetBtn = document.getElementById('resetBtn');
    const scoreSpan = document.getElementById('scoreValue');
    const feedbackDiv = document.getElementById('feedbackMsg');

    function updateScoreUI() { scoreSpan.innerText = Math.floor(currentScore); }
    function parseUserInput(str) {
        str = str.trim();
        if (str.includes('/')) {
            let parts = str.split('/');
            if (parts.length === 2) {
                let num = parseFloat(parts[0]), den = parseFloat(parts[1]);
                if (!isNaN(num) && !isNaN(den) && den !== 0) return num / den;
            }
        }
        let num = parseFloat(str);
        return isNaN(num) ? NaN : num;
    }
    function isAnswerEqual(user, correct) { return Math.abs(user - correct) < 0.001; }
    function addPointsForCorrect() {
        let gain = 10 * difficultyMap[currentDifficulty].factor;
        currentScore += gain;
        updateScoreUI();
        return gain;
    }

    function rand(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; }
    function randFloat(min, max, fixed=2) { return parseFloat((min + Math.random() * (max - min)).toFixed(fixed)); }

    // ======================== 计算题：难度极差极大 ========================
    function generateCalcQuestion(diff) {
        // 简单：0-10 整数加减，无负数，无乘除
        if (diff === 'easy') {
            let a = rand(0, 10);
            let b = rand(0, 10);
            let op = rand(1,2); // 1加 2减
            let answer, text;
            if (op === 1) { answer = a + b; text = `${a} + ${b}`; }
            else { 
                // 确保非负
                if (a < b) [a,b] = [b,a];
                answer = a - b;
                text = `${a} - ${b}`;
            }
            return { text: text + " = ?", answer: answer };
        }
        // 中等：整数加减乘除，简单小数一位
        else if (diff === 'medium') {
            let type = rand(1,4);
            let a,b,answer;
            if (type <= 2) { // 加减 范围0-20
                a = rand(0,20);
                b = rand(0,20);
                if (type===1) { answer = a+b; text = `${a} + ${b}`; }
                else { if(a<b)[a,b]=[b,a]; answer=a-b; text=`${a} - ${b}`; }
            } else if (type === 3) { // 乘法 1-10
                a = rand(1,10); b = rand(1,10);
                answer = a*b; text = `${a} × ${b}`;
            } else { // 除法 整除
                b = rand(1,10);
                a = b * rand(1,10);
                answer = a/b; text = `${a} ÷ ${b}`;
            }
            return { text: text + " = ?", answer: answer };
        }
        // 困难：两位小数加减乘除，简单分数
        else if (diff === 'hard') {
            let style = rand(1,5);
            let getNum = () => {
                if (rand(1,3)===1) return randFloat(1, 30, 1);
                else return rand(1, 40);
            };
            let a=getNum(), b=getNum();
            let answer, text;
            if(style===1){ answer=a+b; text=`${a} + ${b}`; }
            else if(style===2){ answer=a-b; text=`${a} - ${b}`; }
            else if(style===3){ answer=a*b; text=`${a} × ${b}`; }
            else { if(b===0)b=1; answer=a/b; text=`${a} ÷ ${b}`; }
            answer = parseFloat(answer.toFixed(4));
            return { text: text + " = ?", answer: answer };
        }
        // 地狱：多层混合运算 + 分数/小数嵌套，极度复杂
        else {
            let style = rand(1,8);
            let getNumComplex = () => {
                if (rand(1,2)===1) {
                    let den = rand(2, 15);
                    let num = rand(1, den*4);
                    return { val: num/den, str: `${num}/${den}` };
                } else {
                    let v = randFloat(0.5, 50, 2);
                    return { val: v, str: v.toString() };
                }
            };
            let n1 = getNumComplex(), n2 = getNumComplex(), n3 = getNumComplex();
            let v1=n1.val, v2=n2.val, v3=n3.val;
            let answer, text;
            if (style===1) { answer = v1 + v2 * v3; text = `${n1.str} + ${n2.str} × ${n3.str}`; }
            else if (style===2) { answer = (v1 + v2) / (v3+0.001); text = `(${n1.str} + ${n2.str}) ÷ ${n3.str}`; }
            else if (style===3) { answer = v1 * v2 - v3; text = `${n1.str} × ${n2.str} - ${n3.str}`; }
            else if (style===4) { answer = (v1 * v2) / (v3+0.001); text = `${n1.str} × ${n2.str} ÷ ${n3.str}`; }
            else if (style===5) { answer = v1/v2 + v3; text = `${n1.str} ÷ ${n2.str} + ${n3.str}`; }
            else if (style===6) { answer = (v1 - v2) * v3; text = `(${n1.str} - ${n2.str}) × ${n3.str}`; }
            else if (style===7) { answer = (v1 + v2*v3) / (v3+0.5); text = `(${n1.str} + ${n2.str}×${n3.str}) ÷ ${n3.str}`; }
            else { answer = v1*v2*v3; text = `${n1.str} × ${n2.str} × ${n3.str}`; }
            answer = parseFloat(answer.toFixed(5));
            return { text: text + " = ?", answer: answer };
        }
    }

    // ======================== 应用题：地狱难度包含异形/多步方程 ========================
    function generateWordProblem(diff) {
        // 简单应用题：一步加减，极其简单
        if (diff === 'easy') {
            let type = rand(1,3);
            if (type === 1) {
                let apples = rand(1,8);
                let more = rand(1,5);
                let answer = apples + more;
                return { text: `小明有 ${apples} 个苹果，妈妈又给了他 ${more} 个，他现在一共有几个苹果？`, answer: answer };
            } else if (type === 2) {
                let total = rand(5,15);
                let taken = rand(1, total);
                let answer = total - taken;
                return { text: `盒子里有 ${total} 块巧克力，吃掉 ${taken} 块，还剩几块？`, answer: answer };
            } else {
                let kids = rand(2,5);
                let candies = rand(2,8);
                let answer = kids * candies;
                return { text: `每个小朋友分 ${candies} 颗糖，${kids} 个小朋友一共需要多少颗糖？`, answer: answer };
            }
        }
        // 中等应用题：简单乘除，一步方程
        else if (diff === 'medium') {
            let type = rand(1,4);
            if (type === 1) {
                let price = rand(2,15);
                let qty = rand(2,6);
                let answer = price * qty;
                return { text: `一支笔 ${price} 元，买 ${qty} 支需要多少钱？`, answer: answer };
            } else if (type === 2) {
                let total = rand(20,60);
                let people = rand(2,5);
                let answer = total / people;
                return { text: `${total} 元平均分给 ${people} 个人，每人得多少元？`, answer: answer };
            } else if (type === 3) {
                let speed = rand(15,40);
                let time = rand(2,5);
                let answer = speed * time;
                return { text: `汽车速度 ${speed} km/h，行驶 ${time} 小时，路程多少千米？`, answer: answer };
            } else {
                let length = rand(10,30);
                let width = rand(5,15);
                let answer = length * width;
                return { text: `长方形长 ${length} 米，宽 ${width} 米，面积是多少平方米？`, answer: answer };
            }
        }
        // 困难应用题：两步计算，简单分数/百分数
        else if (diff === 'hard') {
            let type = rand(1,5);
            if (type === 1) {
                let original = rand(50,200);
                let percent = rand(10,30);
                let answer = original * percent / 100;
                return { text: `一件商品原价 ${original} 元，打 ${percent}% 折扣，降价多少元？`, answer: answer };
            } else if (type === 2) {
                let speed = rand(30,70);
                let time1 = rand(2,4);
                let time2 = rand(1,3);
                let answer = speed * (time1 + time2);
                return { text: `货车以 ${speed} km/h 的速度行驶 ${time1} 小时，又行驶 ${time2} 小时，一共行驶多少千米？`, answer: answer };
            } else if (type === 3) {
                let total = rand(100,300);
                let ratio = rand(2,5);
                let answer = total / (ratio+1);
                return { text: `甲乙两数之和为 ${total}，甲是乙的 ${ratio} 倍，求乙数。`, answer: answer };
            } else if (type === 4) {
                let radius = rand(3,12);
                let answer = 3.14 * radius * 2;
                return { text: `圆的半径 ${radius} 厘米，周长是多少厘米？(π取3.14)`, answer: parseFloat(answer.toFixed(2)) };
            } else {
                let boys = rand(20,50);
                let girls = rand(15,40);
                let answer = boys - girls;
                return { text: `班级有男生 ${boys} 人，女生 ${girls} 人，男生比女生多多少人？`, answer: answer };
            }
        }
        // 地狱应用题：异形动物、多层方程、分数配比、复杂相遇等
        else {
            let hellType = rand(1,8);
            let answer = 0, text = "";
            if (hellType === 1) {
                // 异形动物：多头多足
                let heads = rand(40, 100);
                let legs = rand(120, 280);
                let aHeads = 2, aFeet = 5, bHeads = 3, bFeet = 7;
                let det = aHeads*bFeet - bHeads*aFeet;
                let x = (heads*bFeet - bHeads*legs) / det;
                answer = Math.round(x);
                text = `👾 异星生物A：2头5足，生物B：3头7足。总头数 ${heads}，总足数 ${legs}，求生物A的数量。`;
            } else if (hellType === 2) {
                // 复杂相遇+停留
                let speedA = rand(45, 95);
                let speedB = rand(35, 75);
                let distance = rand(300, 700);
                let stop = rand(0.8, 2.2);
                let timeLate = rand(1.0, 2.5);
                let t = (distance + speedA * stop) / (speedA + speedB);
                answer = parseFloat((t + timeLate).toFixed(2));
                text = `🚗 甲速 ${speedA} km/h，乙速 ${speedB} km/h，相距 ${distance} km。甲先出发 ${timeLate} 小时后休息 ${stop} 小时，乙在甲出发后立即出发。求从甲出发算起几小时后相遇？`;
            } else if (hellType === 3) {
                // 分数工程+轮流
                let daysA = rand(5, 12);
                let daysB = rand(6, 14);
                let daysC = rand(7, 18);
                let hours = rand(2, 5);
                let rateA = 1/daysA, rateB=1/daysB, rateC=1/daysC;
                let done = rateA*hours/8 + rateB*hours/8;
                let remain = 1 - done;
                let final = remain / ((rateB+rateC)/8);
                answer = parseFloat((hours + hours + final).toFixed(2));
                text = `🏗️ 工程甲需 ${daysA} 天，乙 ${daysB} 天，丙 ${daysC} 天。甲做 ${hours} 小时，乙做 ${hours} 小时，之后乙丙合作完成剩余。求总工时(小时)。(一天8小时)`;
            } else if (hellType === 4) {
                // 利润+税率多重
                let cost = rand(120, 500);
                let mark = rand(40, 90);
                let disc = rand(15, 45);
                let tax = rand(8, 18);
                let sell = cost * (1 + mark/100) * (1 - disc/100);
                let profit = sell * (1 - tax/100) - cost;
                answer = parseFloat(profit.toFixed(2));
                text = `💰 进价 ${cost} 元，提价 ${mark}%，再打 ${disc}% 折扣，最后缴售价 ${tax}% 税，求最终利润。`;
            } else if (hellType === 5) {
                // 浓度配比倒出混合
                let vol = rand(250, 600);
                let concA = rand(25, 65);
                let concB = rand(10, 35);
                let pour = rand(60, 180);
                let saltA = vol * concA/100;
                let saltB = vol * concB/100;
                saltA -= pour * concA/100;
                saltB += pour * concA/100;
                let concBnew = saltB / vol;
                saltB -= pour * concBnew;
                saltA += pour * concBnew;
                let finalConc = (saltA / vol) * 100;
                answer = parseFloat(finalConc.toFixed(2));
                text = `🧪 两容器各 ${vol} g，甲浓度 ${concA}%，乙 ${concB}%。甲倒 ${pour} g 到乙混匀，再倒回 ${pour} g 到甲，求最终甲浓度。`;
            } else if (hellType === 6) {
                // 异形三物种
                let heads = rand(70, 160);
                let feet = rand(200, 420);
                let aHeads=1,aFeet=4, bHeads=2,bFeet=6, cHeads=3,cFeet=9;
                let bCount = rand(5, 25);
                let cCount = rand(4, 20);
                let aCount = (heads - bHeads*bCount - cHeads*cCount) / aHeads;
                answer = Math.round(aCount);
                text = `👾 三种外星生物：甲(1头4足)，乙(2头6足)，丙(3头9足)。已知乙 ${bCount} 只，丙 ${cCount} 只，总头 ${heads}，总足 ${feet}，求甲数量。`;
            } else if (hellType === 7) {
                // 复杂比例+税
                let total = rand(8000, 30000);
                let rA = rand(2,7), rB = rand(3,8), rC = rand(1,5);
                let sumR = rA+rB+rC;
                let partA = total * rA / sumR;
                let taxRate = rand(8, 18);
                let final = partA * (1 - taxRate/100);
                answer = parseFloat(final.toFixed(2));
                text = `🏦 奖金 ${total} 元按 ${rA}:${rB}:${rC} 分给甲乙丙，甲纳税 ${taxRate}%，甲实得多少？`;
            } else {
                // 复杂行程二次相遇
                let speedA = rand(30, 70);
                let speedB = rand(25, 65);
                let distance = rand(200, 500);
                let firstMeet = distance / (speedA+speedB);
                let afterMeet = (distance*2) / (speedA+speedB);
                answer = parseFloat((firstMeet + afterMeet).toFixed(2));
                text = `🚗 甲乙相向而行，速度 ${speedA}、${speedB} km/h，相距 ${distance} km。相遇后继续走到对方起点再立即返回，从出发到第二次相遇共多少小时？`;
            }
            return { text: text, answer: answer };
        }
    }

    function fetchNewQuestion() {
        if (currentMode === 'calc') return generateCalcQuestion(currentDifficulty);
        else return generateWordProblem(currentDifficulty);
    }

    function loadNewQuestion() {
        currentQuestionObj = fetchNewQuestion();
        questionTextDiv.innerText = currentQuestionObj.text;
        answerInput.value = '';
        canSubmit = true;
        submitBtn.disabled = false;
        submitBtn.style.opacity = '1';
        feedbackDiv.className = "feedback";
        let diffName = difficultyMap[currentDifficulty].label;
        feedbackDiv.innerHTML = `📝 ${diffName} 题目，答对得 ${Math.floor(10*difficultyMap[currentDifficulty].factor)} 分！`;
    }

    function handleSubmit() {
        if (!canSubmit) {
            feedbackDiv.innerHTML = "⚠️ 本题已完成，点击下一题！";
            feedbackDiv.className = "feedback wrong";
            return;
        }
        let raw = answerInput.value.trim();
        if (raw === "") { feedbackDiv.innerHTML = "✏️ 输入答案吧"; feedbackDiv.className = "feedback wrong"; return; }
        let userVal = parseUserInput(raw);
        if (isNaN(userVal)) { feedbackDiv.innerHTML = "❓ 数字或分数格式错误"; feedbackDiv.className = "feedback wrong"; return; }
        let correct = currentQuestionObj.answer;
        if (isAnswerEqual(userVal, correct)) {
            let gain = addPointsForCorrect();
            feedbackDiv.innerHTML = `✅ 正确！ +${gain.toFixed(1)} 分 🎉 答案: ${correct}`;
            feedbackDiv.className = "feedback correct";
            canSubmit = false;
            submitBtn.disabled = true;
            submitBtn.style.opacity = '0.6';
        } else {
            feedbackDiv.innerHTML = `❌ 错误！ 正确答案是 ${correct} 。继续加油～`;
            feedbackDiv.className = "feedback wrong";
            canSubmit = false;
            submitBtn.disabled = true;
            submitBtn.style.opacity = '0.6';
        }
    }

    function resetGame() { currentScore = 0; updateScoreUI(); loadNewQuestion(); canSubmit=true; submitBtn.disabled=false; submitBtn.style.opacity='1'; feedbackDiv.innerHTML="🔄 分数已重置，开始新旅程！"; feedbackDiv.className="feedback"; }
    function nextQuestion() { loadNewQuestion(); canSubmit=true; submitBtn.disabled=false; submitBtn.style.opacity='1'; }
    function onSettingChange() {
        currentMode = modeSelect.value;
        currentDifficulty = difficultySelect.value;
        loadNewQuestion();
        canSubmit = true;
        submitBtn.disabled = false;
        submitBtn.style.opacity = '1';
        let diffMsg = difficultyMap[currentDifficulty].label;
        feedbackDiv.innerHTML = `⚙️ 切换至 ${currentMode==='calc'?'计算题':'应用题'}，难度${diffMsg}，每题${Math.floor(10*difficultyMap[currentDifficulty].factor)}分！`;
        feedbackDiv.className = "feedback";
    }

    function init() {
        modeSelect.addEventListener('change', onSettingChange);
        difficultySelect.addEventListener('change', onSettingChange);
        submitBtn.addEventListener('click', handleSubmit);
        nextBtn.addEventListener('click', nextQuestion);
        resetBtn.addEventListener('click', resetGame);
        answerInput.addEventListener('keypress', (e) => { if(e.key==='Enter') { e.preventDefault(); if(!submitBtn.disabled) handleSubmit(); } });
        currentMode = 'calc'; currentDifficulty = 'easy';
        modeSelect.value = 'calc'; difficultySelect.value = 'easy';
        loadNewQuestion();
        updateScoreUI();
    }
    init();
</script>
</body>
</html>
